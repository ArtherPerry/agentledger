<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.agentledger.ui.dashboard.DashboardController"
            style="-fx-background-color:#eef1f0;">
    <top>
        <HBox spacing="16" alignment="CENTER_LEFT"
              style="-fx-background-color:#0C3B3C;-fx-padding:12 20 12 20;">
            <Label text="AgentLedger" style="-fx-text-fill:white;-fx-font-size:16px;-fx-font-weight:bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="branchLabel" style="-fx-text-fill:#cfe3e0;"/>
            <Label fx:id="userLabel" style="-fx-text-fill:white;"/>
        </HBox>
    </top>
    <left>
        <VBox fx:id="sidebar" spacing="2" minWidth="210" prefWidth="210"
              style="-fx-background-color:white;-fx-border-color:#e5e9e7;-fx-border-width:0 1 0 0;-fx-padding:12 8 12 8;"/>
    </left>
    <center>
        <StackPane fx:id="contentArea"/>
    </center>
</BorderPane>