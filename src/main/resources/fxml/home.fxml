<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<ScrollPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.agentledger.ui.home.HomeController"
            fitToWidth="true" style="-fx-background:#eef1f0;-fx-background-color:#eef1f0;">
    <VBox spacing="14">
        <padding><Insets top="22" right="26" bottom="22" left="26"/></padding>
        <Label text="%home.title" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#0C3B3C;"/>

        <HBox fx:id="closeBanner" spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color:#FAEEDA;-fx-background-radius:10;-fx-border-color:#F0D9A8;-fx-border-radius:10;-fx-padding:12 16 12 16;">
            <Label text="ⓘ" style="-fx-text-fill:#633806;-fx-font-size:16px;"/>
            <Label text="%home.notClosed" style="-fx-text-fill:#633806;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="%nav.close" onAction="#onGoClose"/>
        </HBox>

        <HBox spacing="12">
            <VBox styleClass="stat" fx:id="c1" spacing="4" HBox.hgrow="ALWAYS"
                  style="-fx-background-color:white;-fx-background-radius:12;-fx-border-color:#e5e9e7;-fx-border-radius:12;-fx-padding:15 18 15 18;">
                <Label text="%home.stat.txnCount" style="-fx-font-size:11px;-fx-text-fill:#5C6967;"/>
                <Label fx:id="statCount" text="0" style="-fx-font-size:20px;-fx-font-weight:bold;-fx-text-fill:#0C3B3C;"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS"
                  style="-fx-background-color:white;-fx-background-radius:12;-fx-border-color:#e5e9e7;-fx-border-radius:12;-fx-padding:15 18 15 18;">
                <Label text="%home.stat.fee" style="-fx-font-size:11px;-fx-text-fill:#5C6967;"/>
                <Label fx:id="statFee" text="0" style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#2C6E2C;"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS"
                  style="-fx-background-color:white;-fx-background-radius:12;-fx-border-color:#e5e9e7;-fx-border-radius:12;-fx-padding:15 18 15 18;">
                <Label text="%home.stat.comm" style="-fx-font-size:11px;-fx-text-fill:#5C6967;"/>
                <Label fx:id="statComm" text="0" style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#8A5712;"/>
            </VBox>
        </HBox>

        <HBox spacing="12">
            <VBox spacing="4" HBox.hgrow="ALWAYS"
                  style="-fx-background-color:white;-fx-background-radius:12;-fx-border-color:#e5e9e7;-fx-border-radius:12;-fx-padding:15 18 15 18;">
                <Label text="%balance.cash" style="-fx-font-size:11px;-fx-text-fill:#5C6967;"/>
                <Label fx:id="statCash" text="0" style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#0C3B3C;"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS"
                  style="-fx-background-color:white;-fx-background-radius:12;-fx-border-color:#e5e9e7;-fx-border-radius:12;-fx-padding:15 18 15 18;">
                <Label text="%balance.digital" style="-fx-font-size:11px;-fx-text-fill:#5C6967;"/>
                <Label fx:id="statDigital" text="0" style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#0C3B3C;"/>
            </VBox>
        </HBox>

        <VBox spacing="8" style="-fx-background-color:white;-fx-background-radius:12;-fx-border-color:#e5e9e7;-fx-border-radius:12;-fx-padding:16;">
            <Label text="%home.recent" style="-fx-font-weight:bold;-fx-text-fill:#0C3B3C;"/>
            <TableView fx:id="table" prefHeight="280">
                <columns>
                    <TableColumn fx:id="colTime" text="%col.time" prefWidth="150"/>
                    <TableColumn fx:id="colType" text="%col.type" prefWidth="220"/>
                    <TableColumn fx:id="colAcct" text="%col.account" prefWidth="130"/>
                    <TableColumn fx:id="colAmount" text="%col.amount" prefWidth="140"/>
                    <TableColumn fx:id="colStatus" text="%col.status" prefWidth="110"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>