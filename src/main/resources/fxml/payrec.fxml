<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.agentledger.ui.payrec.PayRecController"
      spacing="14" style="-fx-background-color:#eef1f0;">
    <padding><Insets top="22" right="26" bottom="22" left="26"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="%payrec.title" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#0C3B3C;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="%payrec.btn.add" onAction="#onAdd"
                style="-fx-background-color:#0E7C7B;-fx-text-fill:white;-fx-font-weight:bold;"/>
    </HBox>

    <HBox spacing="8">
        <ToggleButton fx:id="tabRecv" text="%payrec.tab.recv" selected="true"/>
        <ToggleButton fx:id="tabPay" text="%payrec.tab.pay"/>
        <ToggleButton fx:id="tabSettled" text="%payrec.tab.settled"/>
    </HBox>

    <HBox spacing="12">
        <VBox spacing="2" HBox.hgrow="ALWAYS"
              style="-fx-background-color:white;-fx-background-radius:12;-fx-border-color:#e5e9e7;-fx-border-radius:12;-fx-padding:14;">
            <Label fx:id="totalLabel" text="%payrec.total.receivable" style="-fx-font-size:11px;-fx-text-fill:#5C6967;"/>
            <Label fx:id="totalValue" text="—" style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#A8312B;"/>
        </VBox>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background:transparent;-fx-background-color:transparent;">
        <VBox fx:id="listBox" spacing="10"/>
    </ScrollPane>
</VBox>