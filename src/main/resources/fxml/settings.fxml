<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.agentledger.ui.settings.SettingsController"
      spacing="14" style="-fx-background-color:#eef1f0;">
    <padding><Insets top="22" right="26" bottom="22" left="26"/></padding>
    <Label text="%settings.title" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#0C3B3C;"/>
    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <VBox fx:id="subNav" spacing="2" minWidth="200" prefWidth="200"
              style="-fx-background-color:white;-fx-background-radius:12;-fx-border-color:#e5e9e7;-fx-border-radius:12;-fx-padding:10;"/>
        <StackPane fx:id="settingsContent" HBox.hgrow="ALWAYS"/>
    </HBox>
</VBox>