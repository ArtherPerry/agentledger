<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.agentledger.ui.settings.ActivityController"
      spacing="12" style="-fx-background-color:white;-fx-background-radius:12;-fx-border-color:#e5e9e7;-fx-border-radius:12;">
    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

    <HBox alignment="CENTER_LEFT">
        <Label text="%activity.title" style="-fx-font-weight:bold;-fx-text-fill:#0C3B3C;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="↻" onAction="#onRefresh"><tooltip><Tooltip text="%common.refresh.tooltip"/></tooltip></Button>
    </HBox>
    <Label text="မည်သူ ဘယ်အချိန် ဘာလုပ်သည်ကို အလိုအလျောက် မှတ်သားသည်။ ဤမှတ်တမ်းကို ပြင်/ဖျက်၍ မရပါ။"
           style="-fx-font-size:11px;-fx-text-fill:#5C6967;" wrapText="true"/>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colTs" text="%col.time" prefWidth="170"/>
            <TableColumn fx:id="colUser" text="%col.user" prefWidth="150"/>
            <TableColumn fx:id="colAction" text="%col.action" prefWidth="160"/>
            <TableColumn fx:id="colDetail" text="%col.detail" prefWidth="320"/>
        </columns>
    </TableView>
</VBox>